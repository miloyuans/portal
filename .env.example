APP_NAME=portal
APP_ENV=development
APP_ADDR=:8080
APP_PUBLIC_URL=http://localhost:8080
WEB_PUBLIC_URL=http://localhost:5173
LOG_LEVEL=INFO

MONGO_URI=mongodb://localhost:27017
MONGO_DB=portal
MONGO_CONNECT_TIMEOUT_SECONDS=10

KEYCLOAK_BASE_URL=http://localhost:8081
KEYCLOAK_REALM=portal
KEYCLOAK_OIDC_CLIENT_ID=portal-api
KEYCLOAK_OIDC_CLIENT_SECRET=portal-api-secret
KEYCLOAK_REDIRECT_URL=http://localhost:8080/api/auth/callback
KEYCLOAK_POST_LOGOUT_REDIRECT_URL=http://localhost:5173/login
KEYCLOAK_ADMIN_CLIENT_ID=portal-sync
KEYCLOAK_ADMIN_CLIENT_SECRET=portal-sync-secret
KEYCLOAK_OIDC_SCOPES=openid,profile,email

SESSION_COOKIE_NAME=portal_session
SESSION_SIGNING_KEY=portal-signing-key
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Lax
SESSION_IDLE_TIMEOUT_MINUTES=15
SESSION_ABSOLUTE_TIMEOUT_MINUTES=480
SESSION_STATE_COOKIE_NAME=portal_oidc_state
SESSION_NONCE_COOKIE_NAME=portal_oidc_nonce
SESSION_STATE_COOKIE_MAX_AGE_SECONDS=300

SYNC_ON_LOGIN=true
SYNC_TIMEOUT_SECONDS=10

CORS_ALLOWED_ORIGINS=http://localhost:5173

PORTAL_API_BASE_URL=http://localhost:8080/api
PORTAL_APP_TITLE=Portal

KEYCLOAK_BOOTSTRAP_ADMIN_USER=admin
KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD=admin123
